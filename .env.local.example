PORT=3000
NODE_ENV=development
FRONTEND_ORIGINS=http://localhost:4173,http://localhost:3000,http://10.0.2.2:3000

# Local database. Use DATABASE_URL for Aiven/Postgres, or DB_* for a local DB.
DB_DIALECT=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNC_ON_START=true
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=shopfood

JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_TTL_DAYS=30

GOOGLE_WEB_CLIENT_ID=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Garden Fresh
EMAIL_FROM_ADDRESS=

UPLOAD_MAX_FILE_SIZE_MB=5

PAYMENT_GATEWAY=zalopay
ZALOPAY_ENV=sandbox
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_BANK_CODE=
PUBLIC_BASE_URL=http://localhost:3000
ZALOPAY_REDIRECT_URL=

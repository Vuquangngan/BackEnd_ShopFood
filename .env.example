PORT=3000
FRONTEND_ORIGINS=http://localhost:4173,https://vuquangngan.github.io
DB_DIALECT=postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNC_ON_START=true
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=
DB_NAME=shopfood
JWT_SECRET=secretkey
JWT_EXPIRES_IN=2h
GOOGLE_WEB_CLIENT_ID=

# Cau hinh email gui mat khau tam thoi
# Vi du voi Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_SECURE=false
# EMAIL_PASS la mat khau ung dung 16 ky tu, khong phai mat khau dang nhap Gmail
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=ShopFood
EMAIL_FROM_ADDRESS=
UPLOAD_MAX_FILE_SIZE_MB=5

# ZaloPay app payment
# Sandbox: ZALOPAY_ENV=sandbox, Production: ZALOPAY_ENV=production
# PUBLIC_BASE_URL phai la URL public de ZaloPay callback duoc, vi du https://abc.ngrok-free.app
PAYMENT_GATEWAY=zalopay
ZALOPAY_ENV=sandbox
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_BANK_CODE=
PUBLIC_BASE_URL=
ZALOPAY_REDIRECT_URL=



PORT=3000
NODE_ENV=production
FRONTEND_ORIGINS=https://vuquangngan.github.io,http://localhost:4173

# Server database. Prefer DATABASE_URL on Render/Aiven.
DB_DIALECT=postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNC_ON_START=false
DATABASE_URL=

JWT_SECRET=
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_TTL_DAYS=30

GOOGLE_WEB_CLIENT_ID=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Garden Fresh
EMAIL_FROM_ADDRESS=

UPLOAD_MAX_FILE_SIZE_MB=5

PAYMENT_GATEWAY=zalopay
ZALOPAY_ENV=sandbox
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_BANK_CODE=
PUBLIC_BASE_URL=
ZALOPAY_REDIRECT_URL=
